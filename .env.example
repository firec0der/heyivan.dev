# Docker Compose variable defaults.
# Copy to .env and edit for local overrides — .env is gitignored.

# Host ports
WEB_PORT=3344
STORYBOOK_PORT=3345

# Polling flags for HMR inside Docker.
# CHOKIDAR_USEPOLLING=true is required on Linux for Storybook HMR — Vite's
# chokidar watcher does not receive inotify events across the bind-mount
# namespace boundary without it. Set to false only if you know you don't
# need Storybook live updates.
# On macOS (VirtioFS), both flags may be needed if HMR feels sluggish.
WATCHPACK_POLLING=false
CHOKIDAR_USEPOLLING=true

# Cloudflare Web Analytics — leave blank to disable.
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=
